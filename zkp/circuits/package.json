{
  "name": "@civicos/zkp-circuits",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CivicOS Circom/Groth16 circuits and local test-vector tooling.",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:vote": "mkdir -p build && circom2 circuits/credential_commitment_vote.circom --r1cs --wasm --sym -o build -l node_modules/circomlib/circuits",
    "build:tally": "mkdir -p build && circom2 circuits/encrypted_choice_tally.circom --r1cs --wasm --sym -o build -l node_modules/circomlib/circuits",
    "build:circuit": "npm run build:vote && npm run build:tally",
    "vectors": "node scripts/generate-test-vectors.mjs",
    "test:vectors": "node scripts/verify-test-vectors.mjs",
    "setup:dev": "node scripts/setup-dev-groth16.mjs",
    "ptau:rc": "node scripts/prepare-rc-ptau.mjs",
    "setup:rc": "node scripts/setup-rc-groth16.mjs",
    "transcripts": "node scripts/write-phase2-transcripts.mjs",
    "manifests": "node scripts/write-artifact-manifests.mjs",
    "fixtures": "node scripts/write-proof-fixtures.mjs",
    "prove:dev": "node scripts/prove-dev.mjs",
    "test": "npm run vectors && npm run test:vectors"
  },
  "devDependencies": {
    "circom2": "^0.2.23",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  }
}
