{
  "name": "iland-backend",
  "version": "0.0.87",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "node scripts/prepare-zkp-prover-artifacts.mjs && bun src/server.ts",
    "typecheck": "bunx tsc --noEmit",
    "audit:verify": "node scripts/verify-public-audit.mjs",
    "phase7:acceptance": "node scripts/phase7-devnet-acceptance.mjs",
    "phase9:readiness": "node scripts/check-phase9-readiness.mjs",
    "phase9:pin-artifacts": "node scripts/pin-groth16-artifacts.mjs",
    "phase9:regression": "node scripts/run-phase9-regression-suite.mjs",
    "phase10:readiness": "node scripts/check-phase10-cleanliness.mjs",
    "zkp:env": "node scripts/print-zkp-artifact-env.mjs",
    "zkp:prepare-prover-artifacts": "node scripts/prepare-zkp-prover-artifacts.mjs",
    "zkp:tally-proof": "bun scripts/generate-submit-tally-proof.ts",
    "zkp:publish-credential-roots": "bun scripts/publish-credential-roots.ts",
    "zkp:replace-example-polls": "bun scripts/replace-example-polls-with-production-zkp.ts",
    "oidc:signing-keys": "bun scripts/oidc-signing-keys.ts",
    "oidc:clients": "bun scripts/oidc-clients.ts"
  },
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "@solana/web3.js": "^1.98.0",
    "@supabase/supabase-js": "^2.57.4",
    "cbor-x": "^1.6.4",
    "circomlibjs": "^0.1.7",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "snarkjs": "^0.7.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "bun-types": "^1.2.15",
    "typescript": "^5.9.3"
  }
}
