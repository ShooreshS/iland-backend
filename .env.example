NODE_ENV=development
# Usually unset. Backend admin scripts set this themselves so they can validate
# Supabase credentials without requiring request-serving app-attestation env.
ILAND_ENV_VALIDATION_SCOPE=server
HOST=0.0.0.0
PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=openssl rand -hex 32
ENABLE_DEV_VIEWER_AUTH=true
DEV_VIEWER_ID_HEADER=x-dev-viewer-id
AUTH_ISSUER=https://iland-backend-production.up.railway.app/idp
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=3
AUTH_REQUIRE_ATTESTED_SESSIONS_FOR_PROTECTED_ROUTES=true
AUTH_ENABLE_TRANSITIONAL_CRYPTO_BYPASS=true
AUTH_IOS_TEAM_ID=
AUTH_IOS_BUNDLE_ID=com.shooresh.iland
AUTH_ANDROID_PACKAGE_NAME=com.shooresh.iland
AUTH_IOS_APP_ATTEST_ENVIRONMENT=development
AUTH_ANDROID_ALLOWED_SIGNING_CERT_DIGESTS=
# Server-side Play Integrity decode uses service-account OAuth, not an API key.
# Prefer the full JSON copied from Google Cloud into Railway as one variable.
AUTH_ANDROID_GOOGLE_SERVICE_ACCOUNT_JSON=
# Or use split values if your deployment environment handles multiline secrets poorly.
AUTH_ANDROID_GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
AUTH_ANDROID_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# OIDC signing private keys are stored in Railway env vars referenced by
# oidc_signing_keys.private_key_ref. Example generated by:
# bun run oidc:signing-keys seed -- --retire-existing
# OIDC_RS256_PRIVATE_KEY_RS256_YYYYMMDDTHHMMSSZ_RANDOM=
WALLET_ISSUER_ID=did:iland:backend:issuer:v0.0.86
WALLET_ISSUER_SIGNING_SECRET=openssl rand -hex 64
VERIFIED_IDENTITY_PEPPER=openssl rand -hex 64
POLL_MAP_REFRESH_WORKER_ENABLED=true
POLL_MAP_REFRESH_INTERVAL_MS=10000
POLL_MAP_REFRESH_PENDING_THRESHOLD=10
POLL_MAP_REFRESH_MAX_DELAY_MS=60000
POLL_MAP_REFRESH_MAX_POLLS_PER_CYCLE=20
MAP_ENABLE_ALL_POLLS_DEBUG=false

# Public Solana audit/token configuration. Do not store private keys or seed
# phrases in backend env. Phase 6 records SHOLAN metadata only; transaction
# signing is a later phase and network fees are paid in SOL.
SOLANA_AUDIT_CLUSTER=mainnet-beta
SOLANA_AUDIT_PROGRAM_ID=2hnBkFjtErxbLCtTevhiW2GGTjDp1EHctshX3ebPEfRt
SOLANA_AUDIT_TOKEN_MINT=GJRpZhWZcLGP8ZUKggxDTw7y5N3LGXa2gWqKRSLDWiBq
SOLANA_AUDIT_TOKEN_PROGRAM=TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb
SOLANA_AUDIT_REGISTRY_AUTHORITY=
SOLANA_AUDIT_TREASURY=
SOLANA_AUDIT_FEE_PAYER_PUBLIC_KEY=
SOLANA_AUDIT_DEFAULT_FEE_MODE=civicos-sponsored
SOLANA_AUDIT_SPONSORSHIP_ENABLED=true
SOLANA_AUDIT_USER_PAID_FEES_ENABLED=false
