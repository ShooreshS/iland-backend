NODE_ENV=development
HOST=0.0.0.0
PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=openssl rand -hex 32
ENABLE_DEV_VIEWER_AUTH=true
DEV_VIEWER_ID_HEADER=x-dev-viewer-id
AUTH_ISSUER=https://iland-backend-production.up.railway.app/idp
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=3
AUTH_REQUIRE_ATTESTED_SESSIONS_FOR_PROTECTED_ROUTES=true
AUTH_ENABLE_TRANSITIONAL_CRYPTO_BYPASS=true
WALLET_ISSUER_ID=did:iland:backend:issuer:v0.0.86
WALLET_ISSUER_SIGNING_SECRET=openssl rand -hex 64
VERIFIED_IDENTITY_PEPPER=openssl rand -hex 64
POLL_MAP_REFRESH_WORKER_ENABLED=true
POLL_MAP_REFRESH_INTERVAL_MS=10000
POLL_MAP_REFRESH_PENDING_THRESHOLD=10
POLL_MAP_REFRESH_MAX_DELAY_MS=60000
POLL_MAP_REFRESH_MAX_POLLS_PER_CYCLE=20
MAP_ENABLE_ALL_POLLS_DEBUG=false
