NODE_ENV=development
# Usually unset. Backend admin scripts set this themselves so they can validate
# Supabase credentials without requiring request-serving app-attestation env.
ILAND_ENV_VALIDATION_SCOPE=server
HOST=0.0.0.0
PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=openssl rand -hex 32
ENABLE_DEV_VIEWER_AUTH=true
DEV_VIEWER_ID_HEADER=x-dev-viewer-id
AUTH_ISSUER=https://iland-backend-production.up.railway.app/idp
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=3
AUTH_REQUIRE_ATTESTED_SESSIONS_FOR_PROTECTED_ROUTES=true
AUTH_ENABLE_TRANSITIONAL_CRYPTO_BYPASS=true
AUTH_IOS_TEAM_ID=
AUTH_IOS_BUNDLE_ID=com.shooresh.iland
AUTH_ANDROID_PACKAGE_NAME=com.shooresh.iland
AUTH_IOS_APP_ATTEST_ENVIRONMENT=development
AUTH_ANDROID_ALLOWED_SIGNING_CERT_DIGESTS=
# Server-side Play Integrity decode uses service-account OAuth, not an API key.
# Prefer the full JSON copied from Google Cloud into Railway as one variable.
AUTH_ANDROID_GOOGLE_SERVICE_ACCOUNT_JSON=
# Or use split values if your deployment environment handles multiline secrets poorly.
AUTH_ANDROID_GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
AUTH_ANDROID_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# OIDC signing private keys are stored in Railway env vars referenced by
# oidc_signing_keys.private_key_ref. Example generated by:
# bun run oidc:signing-keys seed -- --retire-existing
# OIDC_RS256_PRIVATE_KEY_RS256_YYYYMMDDTHHMMSSZ_RANDOM=
WALLET_ISSUER_ID=did:iland:backend:issuer:v0.0.86
WALLET_ISSUER_SIGNING_SECRET=openssl rand -hex 64
VERIFIED_IDENTITY_PEPPER=openssl rand -hex 64
POLL_MAP_REFRESH_WORKER_ENABLED=true
POLL_MAP_REFRESH_INTERVAL_MS=10000
POLL_MAP_REFRESH_PENDING_THRESHOLD=10
POLL_MAP_REFRESH_MAX_DELAY_MS=60000
POLL_MAP_REFRESH_MAX_POLLS_PER_CYCLE=20
MAP_ENABLE_ALL_POLLS_DEBUG=false

# Public Solana audit/token configuration. Network fees are paid in SOL, not
# SHOLAN. Keep transactions disabled unless intentionally running an on-chain
# audit publication test.
SOLANA_AUDIT_CLUSTER=mainnet-beta
SOLANA_AUDIT_RPC_URL=
SOLANA_AUDIT_PROGRAM_ID=FsXuodQtkWjE1EZEAUskvRuj4bGMrKZAHAEf4WEk4oRo
SOLANA_AUDIT_TOKEN_MINT=GJRpZhWZcLGP8ZUKggxDTw7y5N3LGXa2gWqKRSLDWiBq
SOLANA_AUDIT_TOKEN_PROGRAM=TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb
SOLANA_AUDIT_REGISTRY_AUTHORITY=
SOLANA_AUDIT_TREASURY=
SOLANA_AUDIT_FEE_PAYER_PUBLIC_KEY=
# Controlled test mode only: set this directly in Railway, never commit it.
# Accepted formats: solana-keygen JSON array, base64 bytes, or comma-separated bytes.
SOLANA_AUDIT_FEE_PAYER_SECRET_KEY=
SOLANA_AUDIT_DEFAULT_FEE_MODE=civicos-sponsored
SOLANA_AUDIT_SPONSORSHIP_ENABLED=true
SOLANA_AUDIT_USER_PAID_FEES_ENABLED=false
SOLANA_AUDIT_TRANSACTIONS_ENABLED=false
SOLANA_AUDIT_MAINNET_CONFIRMED=false

# Production ZKP verifier configuration. The values below are the internal
# release-candidate vote/tally artifacts for devnet/internal testing. Replace
# them after the real multi-contributor production ceremony.
ZKP_GROTH16_VOTE_VERIFIER_ENABLED=false
ZKP_GROTH16_VOTE_CIRCUIT_ID=civicos-groth16-vote-circuit-v1
ZKP_GROTH16_VOTE_VERIFIER_KEY_HASH=edbb91b2e0bf49013ac3c4e214c1101d0b85724c5e818ef53c7e8175a268ec46
ZKP_GROTH16_VOTE_PUBLIC_INPUT_SCHEMA_VERSION=civicos-groth16-vote-public-inputs-v1
ZKP_GROTH16_VOTE_TRUSTED_SETUP_TRANSCRIPT_HASH=c3bee55503224e38a2d02e6cf5d460afec6cd8dfa622be481e1b0f2d05c4408b
ZKP_GROTH16_VOTE_ARTIFACT_MANIFEST_PATH=src/zkp-artifacts/groth16-vote/credential_commitment_vote.manifest.json
ZKP_GROTH16_VOTE_ARTIFACT_MANIFEST_HASH=9e77769e7fec24d5e860e75976aa0afcac439b93f42b8ed604c9754f95786c4b
# Legacy vote aliases are supported for compatibility, but prefer the
# vote-specific names above.
ZKP_GROTH16_PUBLIC_INPUT_SCHEMA_VERSION=civicos-groth16-vote-public-inputs-v1
ZKP_GROTH16_TRUSTED_SETUP_TRANSCRIPT_HASH=c3bee55503224e38a2d02e6cf5d460afec6cd8dfa622be481e1b0f2d05c4408b

ZKP_GROTH16_TALLY_VERIFIER_ENABLED=false
ZKP_GROTH16_TALLY_CIRCUIT_ID=civicos-groth16-tally-circuit-v1
ZKP_GROTH16_TALLY_VERIFIER_KEY_HASH=d1caee54892e1b522f63ce45c939b8e146987d429c728447e897f5cd7d68a731
ZKP_GROTH16_TALLY_PUBLIC_INPUT_SCHEMA_VERSION=civicos-groth16-tally-public-inputs-v1
ZKP_GROTH16_TALLY_TRUSTED_SETUP_TRANSCRIPT_HASH=143eadcd0f2f03f92ba7e63d3c119a65a5d9b803df95c202283affeb928da211
ZKP_GROTH16_TALLY_ARTIFACT_MANIFEST_PATH=src/zkp-artifacts/groth16-tally/encrypted_choice_tally.manifest.json
